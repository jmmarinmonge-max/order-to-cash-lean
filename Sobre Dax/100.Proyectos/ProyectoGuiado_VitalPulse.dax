Margen Porc - Promedio = SUM(H_Nv_Ventas[ Margen $]) / SUM(H_Nv_Ventas[Precio total con descuento])

Margen Porc Mes Anterior = CALCULATE([Margen Porc Ultimo Mes - Promedio]; DATEADD(H_Nv_Ventas[ Fecha del pedido];-1;MONTH)
)

Margen Porc Mismo Mes Año Anterior = CALCULATE([Margen Porc Ultimo Mes - Promedio]; DATEADD(H_Nv_Ventas[ Fecha del pedido];-1;year))

Margen Porc Ultimo Mes - Promedio = CALCULATE([Margen Porc - Promedio]; DATESMTD(H_Nv_Ventas[ Fecha del pedido]))

MoM % Ventas $ = 
VAR numerador = [Ventas $ Ult Mes - Suma] - [Ventas $ Mes Anterior - Suma]
VAR denominador = ABS([Ventas $ Mes Anterior - Suma])
VAR resultado = DIVIDE(numerador; denominador; BLANK())
RETURN resultado

MoM % Ventas $ = 
VAR numerador = [Ventas $ Ult Mes - Suma] - [Ventas $ Mes Anterior - Suma]
VAR denominador = ABS([Ventas $ Mes Anterior - Suma])
VAR resultado = DIVIDE(numerador; denominador; BLANK())
RETURN resultado

MoM % Ventas Unidades = 
VAR numerador = [Ventas Unidades Ult Mes - Suma] - [Ventas Unidades Mes Anterior - Suma]
VAR denominador = ABS([Ventas Unidades Mes Anterior - Suma])
VAR resultado = DIVIDE(numerador; denominador; BLANK())
RETURN resultado

MoM% Margen Porc = 
VAR numerador = [Margen Porc Ultimo Mes - Promedio] - [Margen Porc Mes Anterior]
VAR denominador = ABS([Margen Porc Mes Anterior])
VAR resultado = DIVIDE(numerador; denominador; BLANK())
RETURN resultado

Tendencia Margen Porc Ultimos 12 Meses = 
VAR fecha_fin = CALCULATE(MAX(H_Nv_Ventas[ Fecha del pedido]); ALL())
VAR fecha_inicio = EOMONTH(fecha_fin; -12) + 1
VAR resultado = CALCULATE(SUM(H_Nv_Ventas[ Margen $]);
FILTER(D_Fechas; D_Fechas[Fecha] >= fecha_inicio && D_Fechas[Fecha] <= fecha_fin))
RETURN resultado

Tendencia Margen Porc Ultimos 12 Meses = 
VAR fecha_fin = CALCULATE(MAX(H_Nv_Ventas[ Fecha del pedido]); ALL())
VAR fecha_inicio = EOMONTH(fecha_fin; -12) + 1
VAR resultado = CALCULATE(SUM(H_Nv_Ventas[ Margen $]);
FILTER(D_Fechas; D_Fechas[Fecha] >= fecha_inicio && D_Fechas[Fecha] <= fecha_fin))
